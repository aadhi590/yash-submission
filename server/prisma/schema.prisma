datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  queues      Queue[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Queue {
  id               String            @id @default(uuid())
  name             String
  description      String?
  projectId        String
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  priority         Int               @default(1) // 1 = Low, 2 = Medium, 3 = High
  concurrencyLimit Int               @default(5)
  retryPolicyId    String?
  retryPolicy      RetryPolicy?      @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)
  isPaused         Boolean           @default(false)
  jobs             Job[]
  dlqJobs          DeadLetterQueue[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

model RetryPolicy {
  id            String        @id @default(uuid())
  name          String
  strategy      RetryStrategy @default(FIXED)
  delay         Int           @default(5) // in seconds
  maxRetries    Int           @default(3)
  backoffFactor Float         @default(2.0)
  queues        Queue[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

model Job {
  id             String           @id @default(uuid())
  queueId        String
  queue          Queue            @relation(fields: [queueId], references: [id], onDelete: Cascade)
  status         JobStatus        @default(QUEUED)
  payload        Json
  maxRetries     Int              @default(3)
  retryCount     Int              @default(0)
  runAt          DateTime         @default(now())
  claimedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  error          String?
  workerId       String?
  worker         Worker?          @relation(fields: [workerId], references: [id], onDelete: SetNull)
  executions     JobExecution[]
  logs           JobLog[]
  scheduledJob   ScheduledJob?
  dlq            DeadLetterQueue?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([queueId, status, runAt])
  @@index([status])
  @@index([workerId])
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRY
  DLQ
}

model Worker {
  id            String            @id @default(uuid())
  name          String
  hostname      String
  ipAddress     String
  status        WorkerStatus      @default(ACTIVE)
  lastHeartbeat DateTime          @default(now())
  heartbeats    WorkerHeartbeat[]
  jobs          Job[]
  executions    JobExecution[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([lastHeartbeat])
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  timestamp   DateTime @default(now())
  cpuUsage    Float
  memoryUsage Float

  @@index([workerId, timestamp])
}

model JobExecution {
  id            String          @id @default(uuid())
  jobId         String
  job           Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId      String
  worker        Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status        ExecutionStatus
  startedAt     DateTime        @default(now())
  endedAt       DateTime?
  error         String?
  attemptNumber Int
  createdAt     DateTime        @default(now())

  @@index([jobId])
  @@index([workerId])
}

enum ExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

model JobLog {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  message   String
  level     LogLevel @default(INFO)
  timestamp DateTime @default(now())

  @@index([jobId, timestamp])
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model ScheduledJob {
  id             String   @id @default(uuid())
  jobId          String   @unique
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cronExpression String
  nextRunAt      DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([nextRunAt, isActive])
}

model DeadLetterQueue {
  id       String   @id @default(uuid())
  jobId    String   @unique
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  queueId  String
  queue    Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  reason   String?
  failedAt DateTime @default(now())
  payload  Json

  @@index([queueId])
}
